<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_sicm_account" model="ir.ui.view">
        <field name="name">account.move.form.sicm.account</field>
            <field name="model">account.move</field>
            <field eval="10" name="priority"/>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='price_unit']" position="after">
                    <field name="increase" column_invisible="not parent.is_sicm_company"/>
                    <field name="net_price" column_invisible="not parent.is_sicm_company"/>
                </xpath>
            </field>
    </record>

</odoo>
