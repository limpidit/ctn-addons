<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_saleorder_document_inherit_shipping" inherit_id="sale.report_saleorder_document">

        <xpath expr="//t[@t-set='information_block']" position="replace">
            <t t-set="information_block">
                <strong>
                    <t t-if="doc.partner_shipping_id == doc.partner_invoice_id">
                        Invoicing and Shipping Address
                    </t>
                    <t t-else="">
                        Invoicing Address
                    </t>
                </strong>
                <div class="mb-0">
                    <div t-field="doc.partner_invoice_id.name"/>
                    <div t-if="doc.partner_invoice_id.street" t-field="doc.partner_invoice_id.street"/>
                    <div t-if="doc.partner_invoice_id.street2" t-field="doc.partner_invoice_id.street2"/>
                    <div>
                        <span t-if="doc.partner_invoice_id.zip" t-field="doc.partner_invoice_id.zip"/>
                        <span t-if="doc.partner_invoice_id.city" t-field="doc.partner_invoice_id.city"/>
                    </div>
                    <div t-if="doc.partner_invoice_id.state_id" t-field="doc.partner_invoice_id.state_id.name"/>
                    <div t-if="doc.partner_invoice_id.country_id" t-field="doc.partner_invoice_id.country_id.name"/>
                    <div t-if="doc.partner_invoice_id.phone">
                        <i class="fa fa-phone"/> <span t-field="doc.partner_invoice_id.phone"/>
                    </div>
                </div>
                <t t-if="doc.partner_shipping_id != doc.partner_invoice_id">
                    <strong class="d-block mt-3">Shipping Address</strong>
                    <div class="mb-0">
                        <div t-field="doc.partner_shipping_id.name"/>
                        <div t-if="doc.partner_shipping_id.street" t-field="doc.partner_shipping_id.street"/>
                        <div t-if="doc.partner_shipping_id.street2" t-field="doc.partner_shipping_id.street2"/>
                        <div>
                            <span t-if="doc.partner_shipping_id.zip" t-field="doc.partner_shipping_id.zip"/>
                            <span t-if="doc.partner_shipping_id.city" t-field="doc.partner_shipping_id.city"/>
                        </div>
                        <div t-if="doc.partner_shipping_id.state_id" t-field="doc.partner_shipping_id.state_id.name"/>
                        <div t-if="doc.partner_shipping_id.country_id" t-field="doc.partner_shipping_id.country_id.name"/>
                        <div t-if="doc.partner_shipping_id.phone">
                            <i class="fa fa-phone"/> <span t-field="doc.partner_shipping_id.phone"/>
                        </div>
                    </div>
                </t>
            </t>
        </xpath>

        <xpath expr="//t[@t-set='display_discount']" position="before">
            <t t-set="display_reference" t-value="any(l.product_id.default_code for l in (lines_to_report or []))"/>
        </xpath>

        <xpath expr="//t[@t-set='display_discount']" position="before">
            <t t-set="display_increase" t-value="any(l.increase for l in lines_to_report or [])"/>
        </xpath>

        <xpath expr="//th[@name='th_description']" position="before">
            <th name="th_product_ref" t-if="display_reference" class="text-start">Reference</th>
        </xpath>

        <xpath expr="//th[@name='th_priceunit']" position="after">
            <th name="th_increase" t-if="display_increase" class="text-end"><span>Increase%</span></th>
            <th name="th_net_price" t-if="display_increase" class="text-end text-nowrap"><span>Net price</span></th>
        </xpath>

        <xpath expr="//th[@name='th_taxes']" position="replace"/>

        <xpath expr="//td[@name='td_product_name']" position="replace">
            <td name="td_product_ref" t-if="display_reference" t-att-class="padding_class">
                <span t-field="line.product_id.default_code"/>
            </td>
            <td name="td_product_name" t-att-class="padding_class"><span t-field="line.product_id.name"/></td>
        </xpath>

        <xpath expr="//td[@name='td_product_priceunit']" position="after">
            <td t-if="display_increase" name="td_product_increase" class="text-end">
                <t t-if="not collapse_prices"><span t-field="line.increase" t-options="{'widget': 'float', 'precision': 2}">-</span></t>
            </td>
            <td t-if="display_increase" name="td_product_net_price" class="text-end text-nowrap">
                <span t-if="not collapse_prices" t-field="line.net_price" t-options="{'widget': 'monetary', 'display_currency': line.currency_id}">25.00</span>
            </td>
        </xpath>

        <xpath expr="//td[@name='td_product_taxes']" position="replace"/>
        
    </template>
</odoo>