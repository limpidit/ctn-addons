<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_property_form_sicm_sale" model="ir.ui.view">
        <field name="name">res.partner.carrier.property.form.sicm.sale.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//group[@name='sale']" position="inside">
                <field name="show_order_reference_required" invisible="1"/>
                <field name="order_reference_required" invisible="not show_order_reference_required"/>
            </xpath>
        </field>
    </record>

</odoo>
