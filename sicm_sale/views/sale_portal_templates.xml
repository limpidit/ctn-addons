<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="sale_order_portal_content_inherit_address" inherit_id="sale.sale_order_portal_content">
        <xpath expr="//span[@id='shipping_address']//div[@t-field='sale_order.partner_shipping_id']" position="replace">
            <div class="mb-0">
                <div t-field="sale_order.partner_shipping_id.name"/>
                <div t-if="sale_order.partner_shipping_id.street" t-field="sale_order.partner_shipping_id.street"/>
                <div t-if="sale_order.partner_shipping_id.street2" t-field="sale_order.partner_shipping_id.street2"/>
                <div>
                    <span t-if="sale_order.partner_shipping_id.zip" t-field="sale_order.partner_shipping_id.zip"/>
                    <span t-if="sale_order.partner_shipping_id.city" t-field="sale_order.partner_shipping_id.city"/>
                </div>
                <div t-if="sale_order.partner_shipping_id.state_id" t-field="sale_order.partner_shipping_id.state_id.name"/>
                <div t-if="sale_order.partner_shipping_id.country_id" t-field="sale_order.partner_shipping_id.country_id.name"/>
            </div>
        </xpath>

        <xpath expr="//t[@t-set='display_discount']" position="before">
            <t t-set="display_reference" t-value="any(l.product_id.default_code for l in (lines_to_report or []))"/>
        </xpath>

        <xpath expr="//t[@t-set='display_discount']" position="before">
            <t t-set="display_increase" t-value="any(l.increase for l in lines_to_report or [])"/>
        </xpath>

        <xpath expr="//th[@id='product_name_header']" position="before">
            <th id="product_ref_header" t-if="display_reference" class="text-start">Reference</th>
        </xpath>

        <xpath expr="//th[@id='product_unit_price_header']" position="after">
            <th t-if="display_increase" t-attf-class="text-end {{ 'd-none d-sm-table-cell' if report_type == 'html' else '' }}" id="product_increase_header">Increase%</th>
            <th t-if="display_increase" t-attf-class="text-end {{ 'd-none d-sm-table-cell' if report_type == 'html' else '' }}" id="product_net_price_header">Net Price</th>
        </xpath>

        <xpath expr="//th[@id='taxes_header']" position="replace"/>

        <xpath expr="//td[@name='td_product_name']" position="replace">
            <td name="td_product_ref" t-if="display_reference" t-att-class="padding_class"><span t-field="line.product_id.default_code"/></td>
            <td name="td_product_name" t-att-class="padding_class"><span t-field="line.product_id.name"/></td>
        </xpath>

        <xpath expr="//td[@name='td_product_priceunit']" position="replace">
            <td name="td_product_priceunit" t-attf-class="text-end {{ 'd-none d-sm-table-cell' if report_type == 'html' else '' }}">
                <t t-if="not collapse_prices">
                    <div
                        t-if="line.discount &gt;= 0"
                        t-field="line.price_unit"
                        t-att-style="(line.discount and not display_increase) and 'text-decoration: line-through' or None"
                        t-att-class="(line.discount and not display_increase and 'text-danger' or '') + ' text-end'"
                        t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"
                    />
                    <div t-if="line.discount and not display_increase">
                        <t t-out="(1-line.discount / 100.0) * line.price_unit" t-options='{"widget": "float", "decimal_precision": "Product Price"}'/>
                    </div>
                </t>
            </td>
            <td t-if="display_increase" name="td_product_increase" t-attf-class="text-end {{ 'd-none d-sm-table-cell' if report_type == 'html' else '' }}">
                <t t-if="not collapse_prices">
                    <strong t-if="line.increase &gt; 0" class="text-info">
                        <t t-out="((line.increase % 1) and '%s' or '%d') % line.increase"/>%
                    </strong>
                </t>
            </td>
            <td t-if="display_increase" name="td_product_netprice" t-attf-class="text-end {{ 'd-none d-sm-table-cell' if report_type == 'html' else '' }}">
                <t t-if="not collapse_prices">
                    <div t-if="line.discount &gt;= 0"
                        t-field="line.net_price"
                        t-att-style="line.discount and 'text-decoration: line-through' or None"
                        t-att-class="(line.discount and 'text-danger' or '') + ' text-end'"
                        t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"
                    />
                    <div t-if="line.discount">
                        <t t-out="(1-line.discount / 100.0) * line.net_price" t-options='{"widget": "float", "decimal_precision": "Product Price"}'/>
                    </div>
                </t>
            </td>
        </xpath>

        <xpath expr="//td[@name='td_product_taxes']" position="replace"/>

    </template>

</odoo>
