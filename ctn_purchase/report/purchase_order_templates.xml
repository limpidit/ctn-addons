<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_purchaseorder_document_add_vendor_ref_column" inherit_id="purchase.report_purchaseorder_document">

        <xpath expr="//th[@name='th_description']" position="before">
            <t t-set="display_vendor_ref" t-value="False"/>
            <t t-foreach="o.order_line" t-as="l">
                <t t-if="not l.display_type">
                    <t t-set="seller" t-value="l.product_id._select_seller(partner_id=o.partner_id.commercial_partner_id,quantity=l.product_qty)"/>
                    <t t-if="seller and seller.product_code">
                        <t t-set="display_vendor_ref" t-value="True"/>
                    </t>
                </t>
            </t>

            <th name="th_vendor_ref" t-if="display_vendor_ref" class="text-start">
                <strong>Reference</strong>
            </th>
        </xpath>

        <xpath expr="//td[@id='product']" position="replace">

            <td t-if="display_vendor_ref" class="text-start" id="vendor_ref">
                <t t-set="seller" t-value="line.product_id._select_seller(partner_id=o.partner_id.commercial_partner_id,quantity=l.product_qty)"/>
                <span t-out="(seller and seller.product_code) or ''"/>
            </td>

            <td id="product" class="text-start">
                <span t-field="line.product_id.name"/>
            </td>
            </xpath>

    </template>


    <template id="report_purchaseorder_document_no_price" inherit_id="purchase.report_purchaseorder_document">

        <xpath expr="//th[@name='th_price_unit']" position="attributes">
            <attribute name="t-if">not dont_show_prices</attribute>
        </xpath>

        <xpath expr="//th[@name='th_discount']" position="attributes">
            <attribute name="t-if">not dont_show_prices</attribute>
        </xpath>

        <xpath expr="//th[@name='th_taxes']" position="attributes">
            <attribute name="t-if">not dont_show_prices</attribute>
        </xpath>

        <xpath expr="//th[@name='th_subtotal']" position="attributes">
            <attribute name="t-if">not dont_show_prices</attribute>
        </xpath>

        <xpath expr="//span[@t-field='line.price_unit']/ancestor::td[1]" position="attributes">
            <attribute name="t-if">not dont_show_prices</attribute>
        </xpath>

        <xpath expr="//span[@t-field='line.discount']/ancestor::td[1]" position="attributes">
            <attribute name="t-if">not dont_show_prices</attribute>
        </xpath>

        <xpath expr="//span[contains(@t-out, 'tax.tax_label')]/ancestor::td[1]" position="attributes">
            <attribute name="t-if">not dont_show_prices</attribute>
        </xpath>

        <xpath expr="//span[@t-field='line.price_subtotal']/ancestor::td[1]" position="attributes">
            <attribute name="t-if">not dont_show_prices</attribute>
        </xpath>

        <xpath expr="//tr[contains(@class,'is-subtotal')]" position="attributes">
            <attribute name="t-if">not dont_show_prices</attribute>
        </xpath>

        <xpath expr="//div[@id='total']" position="attributes">
            <attribute name="t-if">not dont_show_prices</attribute>
            </xpath>

    </template>

    <template id="report_purchaseorder_noprice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="dont_show_prices" t-value="True"/>
                <t t-call="purchase.report_purchaseorder_document" t-lang="o.partner_id.lang"/>
            </t>
        </t>
    </template>

</odoo>
