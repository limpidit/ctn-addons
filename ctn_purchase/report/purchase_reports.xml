<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    
        <record id="action_report_purchaseorder_noprice" model="ir.actions.report">
            <field name="name">Purchase Order (No Prices)</field>
            <field name="model">purchase.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">ctn_purchase.report_purchaseorder_noprice</field>
            <field name="report_file">ctn_purchase.report_purchaseorder_noprice</field>
            <field name="print_report_name">(object.state in ('draft', 'sent') and 'Request for Quotation - No Prices - %s' % (object.name) or
            'Purchase Order - No Prices - %s' % (object.name))</field>
            <field name="binding_model_id" ref="purchase.model_purchase_order"/>
            <field name="binding_type">report</field>
        </record>
    
    </data>
</odoo>
