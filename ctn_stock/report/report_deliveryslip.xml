<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_delivery_document_ctn" inherit_id="stock.report_delivery_document">
        
       <xpath expr="//table[@name='stock_move_table']/thead/tr/th[@name='th_sm_product']" position="before">
            <th name="th_sm_ref"><strong>Reference</strong></th>
        </xpath>

        <xpath expr="//table[@name='stock_move_table']/tbody//tr/td[span[@t-field='move.product_id']]" position="before">
            <td class="w-auto text-nowrap">
                <span t-esc="move.product_id.default_code or ''"/>
            </td>
        </xpath>

        <xpath expr="//table[@name='stock_move_table']/tbody//span[@t-field='move.product_id']" position="replace">
            <span t-esc="move.product_id.name or ''"/>
        </xpath>

    </template>

</odoo>
