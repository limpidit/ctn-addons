<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_picking_form_inherit_no_dup_vendor_ref" model="ir.ui.view">
        <field name="name">stock.picking.form.no.dup.vendor.ref</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='operations']//field[@name='move_ids']//list//field[@name='product_id']" position="replace">
                <field name="product_id" context="{'default_is_storable': True}" required="1" readonly="(state != 'draft' and not additional) or move_lines_count &gt; 0" force_save="1"/>
            </xpath>

            <xpath expr="//page[@name='operations']//field[@name='move_ids']//list//field[@name='product_id']" position="after">
                <field name="vendor_label" class="fst-italic text-muted" optional="show" readonly="1" column_invisible="parent.picking_type_code != 'incoming'"/>
            </xpath>

        </field>
    </record>

</odoo>
