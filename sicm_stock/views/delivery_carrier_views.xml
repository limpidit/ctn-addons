<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_delivery_carrier_form_sicm_stock" model="ir.ui.view">
        <field name="name">delivery.carrier.form.sicm.stock</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tracking_url']" position="before">
                <field name="is_sicm_company" invisible="1"/>
                <field name="warehouse_ids" widget="many2many_tags" invisible="not is_sicm_company"/>
            </xpath>
        </field>
    </record>

</odoo>
