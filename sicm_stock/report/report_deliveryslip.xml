<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_delivery_document_sicm" inherit_id="stock.report_delivery_document">

        <!-- En-tête colonne Description (avant Ordered) -->
        <xpath expr="//table[@name='stock_move_table']//th[@name='th_sm_ordered']" position="before">
            <th name="th_sm_description"><strong>Description</strong></th>
        </xpath>

        <!-- Cellule Description pour chaque ligne (avant la quantité commandée) -->
        <xpath expr="//table[@name='stock_move_table']//td[span[@t-out='format_number(move.product_uom_qty)']]" position="before">
            <td><em t-if="move.sale_line_description"><t t-out="move.sale_line_description"/></em></td>
        </xpath>

    </template>

    <!-- Lignes avec numéros de série (état done) -->
    <template id="stock_report_delivery_has_serial_move_line_sicm" inherit_id="stock.stock_report_delivery_has_serial_move_line">
        <xpath expr="//td[span[@t-field='move_line.product_id']]" position="after">
            <td><em t-if="move_line.move_id.sale_line_description"><t t-out="move_line.move_id.sale_line_description"/></em></td>
        </xpath>
    </template>

    <!-- Lignes agrégées (état done, sans numéros de série) -->
    <template id="stock_report_delivery_aggregated_move_lines_sicm" inherit_id="stock.stock_report_delivery_aggregated_move_lines">
        <xpath expr="//td[span[contains(@t-out,'aggregated_lines') and contains(@t-out,'name')]]" position="after">
            <t t-set="agg_sale_desc" t-value="o.move_line_ids.filtered(lambda ml: aggregated_lines[line].get('product_id') and ml.product_id == aggregated_lines[line].get('product_id') and ml.move_id.sale_line_description)[:1].move_id.sale_line_description"/>
            <td><em t-if="agg_sale_desc"><t t-out="agg_sale_desc"/></em></td>
        </xpath>
    </template>

</odoo>
